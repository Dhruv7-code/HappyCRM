# ── Local development ──────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real values.

# Backend API base URL.
# - Local dev: http://localhost:5050  (matches launchSettings.json)
# - Production (Vercel): set VITE_API_URL to your Railway backend URL,
#   e.g. https://internaldashboard-api-production.up.railway.app
VITE_API_URL=http://localhost:5050
