# ── .NET build output ─────────────────────────────────────────────────────────
# Match bin/ and obj/ at any depth (src/*, tests/*, etc.)
**/bin/
**/obj/

# ── .NET tooling / IDE ────────────────────────────────────────────────────────
*.user
*.suo
.vs/
*.nupkg
*.snupkg
backend/TestResults/

# VS Code REST client scratch files — dev tool only, not needed in CI/prod
*.http

# ── Secrets & environment-specific config ─────────────────────────────────────
# appsettings.Development.json contains dev DB connection strings — use .NET
# user secrets locally and Railway env vars in production instead
backend/src/**/appsettings.Development.json

# .NET user secrets
**/secrets.json
backend/appsettings.Local.json

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
nohup.out

# ── Node / Frontend ───────────────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.env
frontend/.env.local
frontend/.env.*.local
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
